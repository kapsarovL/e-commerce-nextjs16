{
  "name": "e-commerce-nextjs16",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "browserslist": {
    "production": [
      "last 2 versions",
      "not dead",
      "> 0.5%"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "node --eval \"if (!process.env.CI) require('node:child_process').execSync('husky', {stdio:'inherit'});\""
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.12",
    "@neondatabase/serverless": "^1.1.0",
    "@uploadthing/react": "^7.3.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "dotenv-flow": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "immer": "^11.1.11",
    "lucide-react": "^0.577.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-error-boundary": "6.1.2",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "svix": "^1.96.1",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uploadthing": "^7.7.4",
    "vaul": "^1.1.2",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@next/eslint-plugin-next": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@size-limit/file": "^12.1.0",
    "@size-limit/webpack": "^12.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "^19.1.0-rc.3",
    "bundlewatch": "^0.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.1.2",
    "sharp": "^0.34.5",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "path-to-regexp": "8.4.0",
      "effect": ">=3.20.0",
      "hono": ">=4.12.27",
      "@hono/node-server": ">=1.19.13",
      "undici": "7.28.0",
      "qs": "6.15.3",
      "js-yaml": "4.3.0",
      "postcss": ">=8.5.10",
      "ip-address": ">=10.1.1",
      "axios": "0.32.0"
    }
  },
  "size-limit": [
    {
      "name": "Main bundle",
      "path": ".next/static/chunks/main-*.js",
      "limit": "80 kB",
      "gzip": true
    },
    {
      "name": "Framework chunk",
      "path": ".next/static/chunks/framework-*.js",
      "limit": "50 kB",
      "gzip": true
    },
    {
      "name": "App shell",
      "path": ".next/static/chunks/pages/_app-*.js",
      "limit": "20 kB",
      "gzip": true
    },
    {
      "name": "Home page",
      "path": ".next/static/chunks/pages/index-*.js",
      "limit": "30 kB",
      "gzip": true
    },
    {
      "name": "Checkout page",
      "path": ".next/static/chunks/pages/checkout-*.js",
      "limit": "40 kB",
      "gzip": true
    }
  ]
}
