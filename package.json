    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10",
