    "dotenv": "^17.3.1",
    "dotenv-flow": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "eslint": "10.2.0",
    "immer": "^11.1.4",
    "lucide-react": "^0.577.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "6.1.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "svix": "^1.90.0",
    "swr": "^2.4.1",
